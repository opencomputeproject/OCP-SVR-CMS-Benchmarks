# =============================================================================
# LMBench — Maru + Llama 3.1 8B — Synthetic Workload
# =============================================================================

HOST_RESULTS_DIR=./results

# -- Auth --
HF_TOKEN=<your-hf-token>

# -- Model --
LMBENCH_MODEL_URL=meta-llama/Llama-3.1-8B-Instruct
LMBENCH_API_TYPE=completions
VLLM_MAX_MODEL_LEN=4096

# -- Device --
LMBENCH_DEVICE=cpu
VLLM_CPU_KVCACHE_SPACE=8
VLLM_CPU_OMP_THREADS_BIND=auto
VLLM_CPU_DTYPE=auto
VLLM_CPU_TP=1

# -- Backend: Maru --
LMCACHE_BACKEND=maru
LMCACHE_MARU_HOST=localhost
LMCACHE_MARU_PORT=5555
LMCACHE_MARU_POOL_SIZE=4

# -- Workload: Synthetic --
# Tuned for CPU inference — lower user counts and QPS to avoid overwhelming
# a CPU-only backend. Llama 8B on CPU does ~5-15 tok/s, so keep QPS modest.
LMBENCH_SUITE_NAME=maru-synthetic-llama8b
LMBENCH_WORKLOADS=synthetic

# Warmup: 10 users prepopulate KV cache in Maru before measurement
SYNTHETIC_NUM_USERS_WARMUP=10
# Measurement: 20 users
SYNTHETIC_NUM_USERS=20
# 5 conversation rounds per user (multi-turn to exercise KV cache reuse)
SYNTHETIC_NUM_ROUNDS=5
# 512-token system prompt (shared across users — tests prefix caching)
SYNTHETIC_SYSTEM_PROMPT=512
# 2048-token chat history (within model's 4096 context window)
SYNTHETIC_CHAT_HISTORY=2048
# 256-token answers (shorter = faster iterations on CPU)
SYNTHETIC_ANSWER_LEN=256
# 0.2 QPS — ~1 request every 5 seconds (CPU can keep up)
SYNTHETIC_QPS=0.2
SYNTHETIC_USE_SHAREGPT=false

# -- Infrastructure (don't change) --
LMBENCH_INFRASTRUCTURE=Local-Flat
LMBENCH_SUITE=custom
LMBENCH_BASELINE_TYPE=Flat
