# =============================================================================
# LMBench + LMCache — Maru CXL Backend Configuration
# =============================================================================
# Assumes maru-server is already running on the host.

HOST_RESULTS_DIR=./results

# -- Auth --
HF_TOKEN=<your-hf-token-here>

# -- Model --
LMBENCH_MODEL_URL=meta-llama/Llama-3.1-8B-Instruct
LMBENCH_API_TYPE=completions
VLLM_MAX_MODEL_LEN=4096

# -- Device --
LMBENCH_DEVICE=cpu
VLLM_CPU_KVCACHE_SPACE=4
VLLM_CPU_OMP_THREADS_BIND=auto
VLLM_CPU_DTYPE=auto
VLLM_CPU_TP=1

# -- Backend: Maru --
LMCACHE_BACKEND=maru
LMCACHE_MARU_HOST=localhost
LMCACHE_MARU_PORT=5555
LMCACHE_MARU_POOL_SIZE=4

# -- Workloads --
LMBENCH_SUITE_NAME=maru-benchmark
LMBENCH_WORKLOADS=synthetic
SYNTHETIC_NUM_USERS_WARMUP=650
SYNTHETIC_NUM_USERS=350
SYNTHETIC_NUM_ROUNDS=20
SYNTHETIC_SYSTEM_PROMPT=0
SYNTHETIC_CHAT_HISTORY=20000
SYNTHETIC_ANSWER_LEN=1000
SYNTHETIC_QPS=0.7
SYNTHETIC_USE_SHAREGPT=false
