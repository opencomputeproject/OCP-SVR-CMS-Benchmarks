# =============================================================================
# LMBench — Maru + Llama 3.1 8B — vLLM Benchmark Workload
# =============================================================================

HOST_RESULTS_DIR=./results

# -- Auth --
HF_TOKEN=<your-hf-token>

# -- Model --
LMBENCH_MODEL_URL=meta-llama/Llama-3.1-8B-Instruct
LMBENCH_API_TYPE=completions
VLLM_MAX_MODEL_LEN=4096

# -- Device --
LMBENCH_DEVICE=cpu
VLLM_CPU_KVCACHE_SPACE=8
VLLM_CPU_OMP_THREADS_BIND=auto
VLLM_CPU_DTYPE=auto
VLLM_CPU_TP=1

# -- Backend: Maru --
LMCACHE_BACKEND=maru
LMCACHE_MARU_HOST=localhost
LMCACHE_MARU_PORT=5555
LMCACHE_MARU_POOL_SIZE=4

# -- Workload: vLLM Benchmark --
# Uses vLLM's native benchmark_serving.py. Random dataset generates
# fixed-length prompts — good for measuring raw throughput without
# KV cache reuse effects. Multiple request rates for latency-throughput curve.
LMBENCH_SUITE_NAME=maru-vllmbench-llama8b
LMBENCH_WORKLOADS=vllm_benchmark

VLLM_BENCH_BACKEND=vllm
VLLM_BENCH_DATASET_NAME=random
VLLM_BENCH_DATASET_PATH=
# 50 prompts — enough for stable measurements on CPU without taking hours
VLLM_BENCH_NUM_PROMPTS=50
# Sweep 3 request rates: light, moderate, saturating
VLLM_BENCH_REQUEST_RATES=0.1,0.2,0.5
VLLM_BENCH_TEMPERATURE=0.0
VLLM_BENCH_TOP_P=1.0
VLLM_BENCH_TOP_K=-1
VLLM_BENCH_MAX_TOKENS=128
VLLM_BENCH_BURSTINESS=1.0
VLLM_BENCH_SEED=42
VLLM_BENCH_DISABLE_TQDM=false
VLLM_BENCH_IGNORE_EOS=true
# Short input/output for CPU — keep total under max_model_len
VLLM_BENCH_RANDOM_INPUT_LEN=512
VLLM_BENCH_RANDOM_OUTPUT_LEN=128
VLLM_BENCH_RANDOM_RANGE_RATIO=0.0

# -- Infrastructure (don't change) --
LMBENCH_INFRASTRUCTURE=Local-Flat
LMBENCH_SUITE=custom
LMBENCH_BASELINE_TYPE=Flat
