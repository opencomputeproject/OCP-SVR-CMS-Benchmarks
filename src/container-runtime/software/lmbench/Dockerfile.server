##################################################################################################
# LMCache Server — vLLM + LMCache Serving Engine
#
# Pre-baked backend configs in /opt/server/configs/. User selects via:
#   LMCACHE_BACKEND=cpu_offload|disk|redis|lmserver|mooncake|infinistore|none|custom
#
# At startup, the selected config template is resolved with envsubst
# and passed to vLLM via LMCACHE_CONFIG_FILE.
##################################################################################################

FROM ocp-cms-base:latest

ARG DEBIAN_FRONTEND=noninteractive
ARG VLLM_DEVICE=cpu

RUN apt-get update && apt-get install -y \
    git python3-dev python3-venv \
    gcc-12 g++-12 libtcmalloc-minimal4t64 \
    curl gettext-base \
    && rm -rf /var/lib/apt/lists/* \
    && update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-12 10 \
       --slave /usr/bin/g++ g++ /usr/bin/g++-12

RUN python3 -m venv /opt/server-venv
ENV PATH="/opt/server-venv/bin:${PATH}"
ENV VIRTUAL_ENV="/opt/server-venv"

RUN pip install --upgrade pip

# -- Install vLLM (CPU or GPU) ------------------------------------------------
RUN if [ "${VLLM_DEVICE}" = "cpu" ]; then \
        VLLM_TARGET_DEVICE=cpu \
        pip install vllm --extra-index-url https://download.pytorch.org/whl/cpu; \
    else \
        pip install vllm; \
    fi

# -- Install LMCache ----------------------------------------------------------
RUN pip install lmcache

# -- Copy pre-baked backend configs and entrypoint -----------------------------
WORKDIR /opt/server
COPY configs/ /opt/server/configs/
COPY server-entrypoint.sh /opt/server/server-entrypoint.sh
RUN chmod +x /opt/server/server-entrypoint.sh

EXPOSE 30080
ENTRYPOINT ["/opt/server/server-entrypoint.sh"]
