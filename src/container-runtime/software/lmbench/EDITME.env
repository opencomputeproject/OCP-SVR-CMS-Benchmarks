# =============================================================================
# LMBench + LMCache — Two-Container OCP CMS Benchmark
# =============================================================================
#
#   Container 1: lmcache-server  — vLLM + LMCache serving engine
#   Container 2: lmbench-client  — Workload generator + CMS reporting
#
# Usage:
#   cp EDITME.env .env && nano .env
#   docker compose build && docker compose up
#
# =============================================================================

HOST_RESULTS_DIR=./results

# #############################################################################
# AUTHENTICATION
# #############################################################################
HF_TOKEN=

# #############################################################################
# MODEL
# #############################################################################
LMBENCH_MODEL_URL=meta-llama/Llama-3.1-8B-Instruct
LMBENCH_API_TYPE=completions
VLLM_MAX_MODEL_LEN=4096

# #############################################################################
# DEVICE — cpu or gpu
# #############################################################################
# cpu = vllm-cpu package (no GPU required, needs AVX512/AVX2 + sufficient DRAM)
# gpu = vllm package (requires nvidia-container-toolkit + --profile gpu)
LMBENCH_DEVICE=cpu

# #############################################################################
# CPU TUNING (when LMBENCH_DEVICE=cpu)
# #############################################################################
VLLM_CPU_KVCACHE_SPACE=4
VLLM_CPU_OMP_THREADS_BIND=auto
VLLM_CPU_DTYPE=auto
# Tensor parallelism — currently requires TP=1 on CPU due to gloo transport
# issues in vllm-cpu. See README troubleshooting for details.
VLLM_CPU_TP=1

# #############################################################################
# GPU TUNING (when LMBENCH_DEVICE=gpu)
# #############################################################################
CUDA_VISIBLE_DEVICES=0
VLLM_GPU_MEMORY_UTILIZATION=0.8

# #############################################################################
# LMCACHE BACKEND — change this one line to swap backends
# #############################################################################
#   none          Plain vLLM, no LMCache (baseline comparison)
#   cpu_offload   LMCache CPU RAM offloading (default, no extra services)
#   disk          LMCache local disk offloading (no extra services)
#   redis         LMCache + Redis (set LMCACHE_REMOTE_HOST/PORT)
#   lmserver      LMCache + LMCache server (lm:// protocol)
#   mooncake      LMCache + Mooncake distributed store
#   infinistore   LMCache + InfiniStore (RDMA)
#   maru          LMCache + Maru CXL shared memory (requires maru-server + /dev/dax*)
#   custom        Your own config (set LMCACHE_CONFIG_FILE_CONTENT)
LMCACHE_BACKEND=cpu_offload

# -- Remote backend connection --
#LMCACHE_REMOTE_HOST=localhost
#LMCACHE_REMOTE_PORT=6379

# -- Maru CXL backend --
#LMCACHE_MARU_HOST=localhost
#LMCACHE_MARU_PORT=5555
#LMCACHE_MARU_POOL_SIZE=4

# -- Mooncake --
#LMCACHE_MOONCAKE_METADATA_SERVER=http://localhost:8080/metadata
#LMCACHE_MOONCAKE_PROTOCOL=tcp

# -- InfiniStore --
#LMCACHE_INFINISTORE_DEVICE=mlx5_1

# -- Custom config --
#LMCACHE_CONFIG_FILE_CONTENT=

# #############################################################################
# DEPLOYMENT MODE
# #############################################################################
#LMBENCH_SERVER_URL=http://192.168.1.100:30080

# #############################################################################
# WORKLOADS
# #############################################################################
LMBENCH_SUITE_NAME=ocp-cms-lmbench
LMBENCH_WORKLOADS=synthetic

SYNTHETIC_NUM_USERS_WARMUP=650
SYNTHETIC_NUM_USERS=350
SYNTHETIC_NUM_ROUNDS=20
SYNTHETIC_SYSTEM_PROMPT=0
SYNTHETIC_CHAT_HISTORY=20000
SYNTHETIC_ANSWER_LEN=1000
SYNTHETIC_QPS=0.7
SYNTHETIC_USE_SHAREGPT=false

SHAREGPT_LIMIT=1000
SHAREGPT_MIN_ROUNDS=10
SHAREGPT_START_ROUND=0
SHAREGPT_QPS=1.34

AGENTIC_NUM_USERS_WARMUP=100
AGENTIC_NUM_AGENTS=10
AGENTIC_NUM_ROUNDS=20
AGENTIC_SYSTEM_PROMPT=0
AGENTIC_CHAT_HISTORY=256
AGENTIC_ANSWER_LEN=20
AGENTIC_NEW_USER_INTERVALS=1

RANDOM_NUM_USERS=100
RANDOM_NUM_ROUNDS=10
RANDOM_PROMPT_LEN=200
RANDOM_ANSWER_LEN=100
RANDOM_QPS=1.0

VLLM_BENCH_BACKEND=vllm
VLLM_BENCH_DATASET_NAME=random
VLLM_BENCH_DATASET_PATH=
VLLM_BENCH_NUM_PROMPTS=100
VLLM_BENCH_REQUEST_RATES=1.0
VLLM_BENCH_TEMPERATURE=0.0
VLLM_BENCH_TOP_P=0.9
VLLM_BENCH_TOP_K=50
VLLM_BENCH_MAX_TOKENS=256
VLLM_BENCH_BURSTINESS=1.0
VLLM_BENCH_SEED=0
VLLM_BENCH_DISABLE_TQDM=true
VLLM_BENCH_IGNORE_EOS=false
VLLM_BENCH_RANDOM_INPUT_LEN=1024
VLLM_BENCH_RANDOM_OUTPUT_LEN=128
VLLM_BENCH_RANDOM_RANGE_RATIO=0.0

STRICT_NUM_CONCURRENT_USERS=10
STRICT_NUM_ROUNDS_PER_USER=5
STRICT_TIME_BETWEEN_REQUESTS=10
STRICT_SHARED_SYSTEM_PROMPT_LEN=100
STRICT_FIRST_PROMPT_LEN=200
STRICT_FOLLOW_UP_PROMPTS_LEN=100
STRICT_ANSWER_LEN=150
STRICT_KV_REUSE_RATIO=1.0

TRACE_FILE=traces/gmi_trace.jsonl
TRACE_START_TIME=0
TRACE_DURATION=full
TRACE_PRESERVE_TIMING=true
TRACE_SPEED_UP=1.0

# #############################################################################
# ADVANCED
# #############################################################################
#LMBENCH_VERSION=main
#EXTRA_PIP_PACKAGES=
#CMS_VERBOSITY=0

# Infrastructure (don't change)
LMBENCH_INFRASTRUCTURE=Local-Flat
LMBENCH_SUITE=custom
LMBENCH_BASELINE_TYPE=Flat
