# Host directory where results will be stored
HOST_RESULTS_DIR=./results

## NUMA / Memory Placement ##
# Mandatory! At least CPU_NUMA_NODE should be configured.

CPU_NUMA_NODE="0"			# CPU NUMA node to bind memcached server and memaslap client to
MEM_NUMA_NODES="0"			# Memory NUMA node(s) to allow, comma separated e.g. "0,2"
#NUMA_POLICY="--interleave=0,2"	# numactl memory policy applied to the memcached server process
					# Examples: "--interleave=0,2", "--preferred=2", "--membind=0"

## Memcached Server Settings ##

MEMCACHED_MEMORY_MB="262144"		# Max memory for memcached in MB (default: 256GB)
#MEMCACHED_THREADS="4"			# Number of memcached worker threads (default: memcached auto)
#MEMCACHED_EXTRA_ARGS=""		# Any additional memcached arguments

## Memaslap Client Settings ##

MEMASLAP_THREADS="16"			# Number of memaslap client threads
MEMASLAP_CONCURRENCY="256"		# Number of concurrent connections
MEMASLAP_DURATION="180s"		# Duration of the benchmark run (e.g. "180s", "5m")
MEMASLAP_WINDOW_SIZE="131072"		# Window size for memaslap (-X flag)
#MEMASLAP_EXTRA_ARGS=""		# Any additional memaslap arguments

## Container Resource Limits ##
# These map to docker --memory and --memory-swap flags

#CONTAINER_MAX_MEMORY=""		# e.g. "155G" - max memory usage
#CONTAINER_MAX_SWAP=""			# e.g. "256G" - max memory+swap usage

## Test Metadata ##

TEST_NOTE="Default Settings"		# Descriptive note appended to the result line
