# =============================================================================
# AIPerf + LMCache — Two-Container OCP CMS Benchmark
# =============================================================================
#
#   Container 1: lmcache-server-gpu  — vLLM + LMCache serving engine (GPU)
#   Container 2: aiperf-client       — AIPerf load generator + CMS reporting
#
# Usage:
#   cp EDITME.env .env && nano .env
#   docker compose build && docker compose up
#
# =============================================================================

HOST_RESULTS_DIR=./results

# #############################################################################
# AUTHENTICATION
# #############################################################################
HF_TOKEN=

# #############################################################################
# MODEL
# #############################################################################
AIPERF_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_MAX_MODEL_LEN=4096

# #############################################################################
# GPU TUNING
# #############################################################################
CUDA_VISIBLE_DEVICES=0
VLLM_GPU_MEMORY_UTILIZATION=0.8

# #############################################################################
# LMCACHE BACKEND — change this one line to swap backends
# #############################################################################
#   none          Plain vLLM, no LMCache (baseline comparison)
#   cpu_offload   LMCache CPU RAM offloading (default, no extra services)
#   disk          LMCache local disk offloading (no extra services)
#   redis         LMCache + Redis (set LMCACHE_REMOTE_HOST/PORT)
#   lmserver      LMCache + LMCache server (lm:// protocol)
#   mooncake      LMCache + Mooncake distributed store
#   infinistore   LMCache + InfiniStore (RDMA)
#   maru          LMCache + Maru CXL shared memory (requires maru-server + /dev/dax*)
#   custom        Your own config (set LMCACHE_CONFIG_FILE_CONTENT)
LMCACHE_BACKEND=cpu_offload

# -- Remote backend connection --
#LMCACHE_REMOTE_HOST=localhost
#LMCACHE_REMOTE_PORT=6379

# -- Maru CXL backend --
#LMCACHE_MARU_HOST=localhost
#LMCACHE_MARU_PORT=5555
#LMCACHE_MARU_POOL_SIZE=4

# -- Maru container tuning --
#MARU_GIT_REF=main
#MARU_RM_HOST=127.0.0.1
#MARU_RM_PORT=9850
#MARU_SERVER_HOST=0.0.0.0
#MARU_LOG_LEVEL=INFO

# -- Mooncake --
#LMCACHE_MOONCAKE_METADATA_SERVER=http://localhost:8080/metadata
#LMCACHE_MOONCAKE_PROTOCOL=tcp

# -- InfiniStore --
#LMCACHE_INFINISTORE_DEVICE=mlx5_1

# -- Custom config --
#LMCACHE_CONFIG_FILE_CONTENT=

# #############################################################################
# DEPLOYMENT MODE
# #############################################################################
# For split-machine deployment, set the server URL on the client machine:
#AIPERF_SERVER_URL=http://192.168.1.100:30080

# #############################################################################
# AIPERF BENCHMARK CONFIGURATION
# #############################################################################
AIPERF_SUITE_NAME=ocp-cms-aiperf

# -- Endpoint --
AIPERF_ENDPOINT_TYPE=chat
AIPERF_STREAMING=true

# -- Load pattern (concurrency mode — set AIPERF_REQUEST_RATE for rate mode) --
AIPERF_CONCURRENCY=10
AIPERF_REQUEST_COUNT=100
#AIPERF_REQUEST_RATE=32

# -- Sequence lengths (synthetic workload) --
#AIPERF_ISL=1024
#AIPERF_OSL=512

# -- Warmup --
AIPERF_WARMUP_REQUEST_COUNT=5

# -- Tokenizer (auto-detected from model if not set) --
#AIPERF_TOKENIZER=

# -- Multi-run confidence (run N times, report statistics) --
AIPERF_NUM_PROFILE_RUNS=1

# -- Public datasets --
# Uncomment ONE of these for dataset-driven benchmarking:
#AIPERF_PUBLIC_DATASET=sharegpt

# -- Custom input files --
# Mount your trace file and set the path:
#AIPERF_INPUT_FILE=/data/traces/my_trace.jsonl
#AIPERF_CUSTOM_DATASET_TYPE=mooncake_trace
#AIPERF_FIXED_SCHEDULE=false

# -- Goodput SLOs (in ms) --
#AIPERF_GOODPUT_TTFT=370
#AIPERF_GOODPUT_LATENCY=648

# -- Extra CLI args (passed directly to aiperf profile) --
#AIPERF_EXTRA_ARGS=

# #############################################################################
# ADVANCED
# #############################################################################
#AIPERF_VERSION=main
#EXTRA_PIP_PACKAGES=
#CMS_VERBOSITY=0
